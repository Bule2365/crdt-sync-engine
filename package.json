{
  "name": "crdt-sync-engine",
  "version": "1.0.0",
  "description": "Real-time Data Synchronization Engine berbasis CRDT",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "dev": "dotenv -e .env -- ts-node src/index.ts",
    "dev:node1": "dotenv -e .env.node-001 -- ts-node src/index.ts",
    "dev:node2": "dotenv -e .env.node-002 -- ts-node src/index.ts",
    "dev:all": "concurrently \"npm run dev:node1\" \"npm run dev:node2\"",
    "dev:watch": "nodemon --exec \"ts-node src/index.ts\" --ext ts",
    "start": "node dist/index.js",
    "clean": "rimraf dist",
    "test": "jest --runInBand --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "crdt",
    "distributed-systems",
    "synchronization",
    "offline-first"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "classic-level": "^1.3.0",
    "express": "^4.19.2",
    "msgpackr": "^1.10.2",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.11",
    "concurrently": "^10.0.3",
    "dotenv-cli": "^11.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "rimraf": "^5.0.7",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
